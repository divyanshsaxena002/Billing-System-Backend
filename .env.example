# Optional: override the port (default 5000)
PORT=5000

# Optional: override the SQLite DB file path (default: ./database.db)
# On Render with Persistent Disk, set this to the mounted path:
# DB_PATH=/var/data/database.db

# CORS: set to your Vercel frontend URL so the browser allows requests
# Example:
# ALLOWED_ORIGIN=https://your-app.vercel.app
ALLOWED_ORIGIN=
